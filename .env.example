# ========================================
# DATABASE CONFIGURATION
# ========================================
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE"

# ========================================
# NEXTAUTH CONFIGURATION (Authentication)
# ========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret-use-openssl-rand-hex-32"

# ========================================
# OAUTH PROVIDERS (Social Login)
# ========================================
# Google OAuth - Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# LinkedIn OAuth - Get from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# Facebook OAuth - Get from https://developers.facebook.com/
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# ========================================
# AI & CONTENT GENERATION (Gemini API)
# ========================================
# Get from https://ai.google.dev/
GEMINI_API_KEY="your-server-side-gemini-key"

# ========================================
# YOUTUBE INTEGRATION
# ========================================
# Get from https://console.cloud.google.com/ (YouTube Data API v3)
# Multiple keys comma-separated for load balancing
YOUTUBE_API_KEYS="youtube_key_1,youtube_key_2"

# ========================================
# RAZORPAY PAYMENT GATEWAY (Indian Users)
# ========================================
# Get from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID="rzp_test_your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Razorpay Plan IDs (Create in Razorpay Dashboard)
NEXT_PUBLIC_RAZORPAY_MONTHLY_PLAN_ID="plan_monthly_premium_id"
NEXT_PUBLIC_RAZORPAY_YEARLY_PLAN_ID="plan_yearly_premium_id"
NEXT_PUBLIC_RAZORPAY_LIFETIME_PLAN_ID="plan_lifetime_id"

# ========================================
# APPLICATION SETTINGS
# ========================================
# Interview Configuration
NEXT_PUBLIC_INTERVIEW_QUESTION_COUNT="10"
NEXT_PUBLIC_INFORMATION="Interview instructions shown on the dashboard interview page"
NEXT_PUBLIC_QUESTION_NOTE="Question note shown in the interview start screen"

# App URL (for WebSocket connections in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ========================================
# EXTERNAL SERVICES (Optional)
# ========================================
# Job API - Leave commented if not using external job provider
# JOB_API_ID="your-job-api-key"
# JOB_API_URL="https://api.example.com/jobs"

# Coding Problems API - Leave commented if using internal problem set
# EXTERNAL_CODING_API_URL="https://api.example.com/problems"

# ========================================
# EMAIL CONFIGURATION (Nodemailer/SendGrid)
# ========================================
# For password reset emails
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="your-email@gmail.com"
MAIL_PASS="your-app-password"
FROM_EMAIL="noreply@neurolearn.com"

# ========================================
# NODE ENVIRONMENT
# ========================================
NODE_ENV="development"
